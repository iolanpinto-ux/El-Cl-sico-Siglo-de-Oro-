---
import { Icon } from "astro-icon/components";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>El Clasico: Siglo de Oro</title>
	</head>
	<body class="bg-black text-white">
		<header class="flex justify-between  justify-stitems-center py-4 px-10 bg-[#131313]">
			<p class="text-yellow-600 text-3xl font-bold italic">El CLÁSICO</p>

			<div class="flex gap-4 italic font-bold text-2x5 uppercase items-center">
				<a href="/">Inicio</a>
				<a href="/estadisticas-e-historial">Historial</a>
				<a href="/jugadores-legendarios">Jugadores</a>
				<a href="/ultimas-noticias">Ultimas noticias</a>
			</div>

			<div class="flex gap-4 items-center">
				<button class="font-bold bg-red-600 text-white px-4 py-3">BOLETOS</button>
				<Icon name="icon1" size={20} class="text-white"/>
			
			</div>

		</header>

		<slot />
		<footer class="">
			<div class="bg-black py-16 px-20 flex flex-col gap-12">
  
  <div class="flex justify-between items-start gap-10">
    
    <div class="flex flex-col gap-4 w-1/4">
      <p class="text-yellow-500 font-bold uppercase text-lg">El Clásico</p>
      <p class="text-gray-500 text-xs leading-relaxed uppercase">
        La experiencia digital definitiva para la rivalidad deportiva más grande del mundo.
      </p>
    </div>

    <div class="flex flex-col gap-4">
      <p class="text-red-700 font-bold uppercase text-xs">Recursos</p>
      <div class="flex flex-col gap-3">
        <p class="text-gray-400 text-xs uppercase cursor-pointer">Política de Privacidad</p>
        <p class="text-gray-400 text-xs uppercase cursor-pointer">Términos de Servicio</p>
        <p class="text-gray-400 text-xs uppercase cursor-pointer">Publicidad</p>
      </div>
    </div>

    <div class="flex flex-col gap-4">
      <p class="text-red-700 font-bold uppercase text-xs">Archivo</p>
      <div class="flex flex-col gap-3">
        <p class="text-gray-400 text-xs uppercase cursor-pointer">Contáctanos</p>
        <p class="text-gray-400 text-xs uppercase cursor-pointer">Hemeroteca</p>
        <p class="text-gray-400 text-xs uppercase cursor-pointer">Clubes Asociados</p>
      </div>
    </div>

    <div class="bg-zinc-900 border-l-2 border-yellow-600 px-8 py-6 flex flex-col gap-4 w-64">
      <p class="text-yellow-500 text-xs font-bold uppercase">Mantente Conectado</p>
      <div class="flex gap-4">
        <div class="text-gray-500 text-lg">📢</div>
        <div class="text-gray-500 text-lg">🎥</div>
        <div class="text-gray-500 text-lg">📶</div>
      </div>
    </div>

  </div>

  <div class="flex justify-center border-t border-zinc-800 pt-8">
    <p class="text-zinc-700 text-[10px] uppercase tracking-widest text-center">
      © 2024 El Clásico Editorial. Todos los derechos reservados. Una experiencia premium sin fronteras.
    </p>
  </div>

</div>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
