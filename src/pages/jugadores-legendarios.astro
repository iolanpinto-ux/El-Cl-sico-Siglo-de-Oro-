---
import Tarjeta from "../components/Tarjeta.astro";
import Layout from "../layouts/Layout.astro";
import { jugadores } from "../data/jugadores.ts";
---

<Layout>
    <section class="">
        <div class="relative min-h-screen bg-black flex items-end justify-center overflow-hidden font-sans">
  
  <img 
    src="/zidane.png" 
    class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale" 
    alt="Zinedine Zidane"
  />

  <div class="relative z-10 w-full max-w-7xl px-12 pb-20 flex flex-col gap-12">
    
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-4">
        <p class="bg-[#ffcc00] text-black text-[10px] font-bold px-2 py-0.5 uppercase italic">
          Leyenda de la semana
        </p>
        <div class="h-[1px] bg-gray-500 w-12"></div>
      </div>

      <div class="flex flex-col leading-[0.8]">
        <p class="text-white text-8xl font-black italic uppercase tracking-tighter">
          ZINEDINE
        </p>
        <p class="text-transparent text-8xl font-black italic uppercase tracking-tighter" style="-webkit-text-stroke: 1px rgba(255,255,255,0.4)">
          ZIDANE
        </p>
      </div>
    </div>

    <div class="flex gap-16">
      <div class="flex flex-col gap-1">
        <p class="text-[#ffcc00] text-[10px] font-bold uppercase tracking-widest">Apariciones</p>
        <p class="text-white text-4xl font-bold italic">227</p>
      </div>
      <div class="flex flex-col gap-1">
        <p class="text-[#ffcc00] text-[10px] font-bold uppercase tracking-widest">Goles</p>
        <p class="text-white text-4xl font-bold italic">49</p>
      </div>
      <div class="flex flex-col gap-1">
        <p class="text-[#ffcc00] text-[10px] font-bold uppercase tracking-widest">Títulos</p>
        <p class="text-white text-4xl font-bold italic">6</p>
      </div>
    </div>
  </div>

  <div class="absolute right-24 bottom-24 z-20 w-80 bg-[#121212]/90 border-l-2 border-[#ffcc00] p-8 flex flex-col gap-6 backdrop-blur-sm">
    <div class="flex flex-col gap-3">
      <p class="text-[#ffcc00] text-[9px] font-bold uppercase tracking-widest">Lo más destacado de mi carrera</p>
      <p class="text-white text-xl font-bold leading-tight">
        La volea de Glasgow: El gol más estético en la historia de las finales de la Liga de Campeones.
      </p>
      <p class="text-gray-400 text-xs leading-relaxed">
        Un maestro del balón cuya elegancia definió una era de los Galácticos del Real Madrid. Zidane no era solo un jugador; era un director de orquesta en el terreno de juego.
      </p>
    </div>
    
    <button class="bg-white text-black text-[10px] font-black uppercase italic py-3 px-6 hover:bg-[#ffcc00] transition-colors">
      Explora tu carrera
    </button>
  </div>

</div>
    </section>
    <section>
        <div class="bg-[#0f0f0f] w-full p-8 flex justify-center items-center font-sans border-b border-white/5">
  
  <div class="max-w-7xl w-full flex flex-col md:flex-row justify-between items-center gap-8">
    
    <div class="flex gap-2">
      <button class="bg-[#eab308] text-black px-6 py-3 text-[10px] font-black uppercase tracking-widest hover:bg-[#facc15] transition-colors">
        TODAS LAS LEYENDAS
      </button>
      
      <button class="bg-[#1c1c1c] text-gray-400 px-6 py-3 text-[10px] font-black uppercase tracking-widest hover:text-white transition-colors">
        FC BARCELONA
      </button>
      
      <button class="bg-[#1c1c1c] text-gray-400 px-6 py-3 text-[10px] font-black uppercase tracking-widest hover:text-white transition-colors">
        REAL MADRID
      </button>
    </div>

    <div class="flex items-center gap-6">
      <p class="text-gray-500 text-[10px] font-bold uppercase tracking-[0.2em]">
        FILTRAR POR ÉPOCA:
      </p>
      
      <div class="flex items-center gap-4 cursor-pointer group">
        <p class="text-[#eab308] text-[10px] font-black uppercase tracking-widest group-hover:text-[#facc15]">
          TODAS LAS ÉPOCAS
        </p>
        <svg class="w-4 h-4 text-[#eab308] group-hover:text-[#facc15]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </div>
    </div>

  </div>
</div>
    </section>

    <section class="py-24 px-10 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-outline-variant/20">
            {jugadores.map((leyenda) => (
                <Tarjeta
                    nombre={leyenda.nombre}
                    equipo={leyenda.equipo}
                    imagen={leyenda.imagen}
                />
            ))}
        </div>
    </section>
    <section>
        <div class="bg-[#0f0f0f] min-h-screen p-12 flex flex-col items-center justify-center font-sans">
  
  <div class="max-w-6xl w-full flex justify-between items-end mb-10">
    <div class="flex flex-col gap-4">
      <div class="flex flex-col leading-none">
        <p class="text-white text-5xl font-black italic uppercase tracking-tighter">LA RIVALIDAD</p>
        <p class="text-[#ffcc00] text-5xl font-black italic uppercase tracking-tighter">EN CIFRAS</p>
      </div>
      <p class="text-gray-500 text-sm max-w-sm leading-tight">
        Siglos de competencia se redujeron al desempeño de élite de sus íconos más legendarios. Comparando las épocas de dominio.
      </p>
    </div>
    <p class="text-[#ffcc00] text-[10px] font-bold uppercase tracking-widest border-b border-[#ffcc00] pb-1 cursor-pointer hover:text-white hover:border-white transition-colors">
      Ver todos los análisis
    </p>
  </div>

  <div class="max-w-6xl w-full flex flex-col md:flex-row gap-4">
    
    <div class="flex-[1.2] bg-[#1a1a1a] p-10 flex flex-col justify-between min-h-[450px] border-l-4 border-[#00529b] relative overflow-hidden">
      <div class="flex flex-col gap-6">
        <p class="bg-[#00529b] text-white text-[9px] font-black px-3 py-1 uppercase tracking-widest self-start">
          Factor de dominancia
        </p>
        <p class="text-white text-5xl font-black italic uppercase leading-[0.9] tracking-tighter max-w-xs">
          LA ÉPOCA DORADA DEL BARÇA
        </p>
      </div>
      
      <div class="flex items-baseline gap-4">
        <p class="text-white text-9xl font-black italic leading-none">14</p>
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest">Trofeos en 4 años</p>
      </div>
    </div>

    <div class="flex-1 flex flex-col gap-4">
      
      <div class="bg-[#1a1a1a] p-8 border-t-2 border-[#ffcc00] flex flex-col gap-6">
        <p class="text-[#ffcc00] text-[10px] font-bold uppercase tracking-widest">Más goles en el Clásico</p>
        
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-end">
              <p class="text-white text-xs font-bold uppercase">Messi</p>
              <p class="text-white text-sm font-black italic">26</p>
            </div>
            <div class="h-1 w-full bg-white/10">
              <div class="h-full w-full bg-[#00529b]"></div>
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-end">
              <p class="text-white text-xs font-bold uppercase">Di Stéfano</p>
              <p class="text-white text-sm font-black italic">18</p>
            </div>
            <div class="h-1 w-full bg-white/10">
              <div class="h-full w-[70%] bg-[#ffcc00]"></div>
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-end">
              <p class="text-white text-xs font-bold uppercase">C. Ronaldo</p>
              <p class="text-white text-sm font-black italic">18</p>
            </div>
            <div class="h-1 w-full bg-white/10">
              <div class="h-full w-[70%] bg-[#ffcc00]"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex gap-4 flex-1">
        <div class="flex-1 bg-[#a51e2d] p-6 flex flex-col items-center justify-center text-center gap-2">
          <p class="text-white text-4xl font-black italic tracking-tighter leading-none uppercase">Estrella</p>
          <p class="text-white text-2xl font-black">57</p>
          <p class="text-white/60 text-[8px] font-bold uppercase tracking-widest leading-tight">Nominaciones al Balón de Oro</p>
        </div>
        <div class="flex-1 bg-[#1a1a1a] p-6 flex flex-col justify-center gap-1">
          <p class="text-gray-500 text-[8px] font-bold uppercase tracking-widest">Racha más larga</p>
          <p class="text-white text-2xl font-black italic uppercase leading-none">7 Victorias</p>
          <p class="text-gray-500 text-[8px] font-bold uppercase mt-2">Real Madrid (1962-65)</p>
        </div>
      </div>

    </div>
  </div>
</div>
    </section>
</Layout>
