---
import Layout from "../layouts/Layout.astro"
---

<Layout>
    <section>
<div class="bg-[#0f0f0f] min-h-screen p-12 flex flex-col items-center justify-center font-sans">
  
  <div class="max-w-6xl w-full flex flex-col gap-2 mb-12">
    <p class="text-[#ffcc00] text-[10px] font-bold uppercase tracking-[0.3em]">
      HISTORICAL ARCHIVE
    </p>
    <div class="flex flex-wrap gap-x-4 items-center leading-none">
      <p class="text-white text-7xl font-black italic uppercase tracking-tighter">
        ESTADÍSTICAS E
      </p>
      <p class="text-[#e21b22] text-7xl font-black italic uppercase tracking-tighter">
        HISTORIAL
      </p>
    </div>
  </div>

  <div class="max-w-6xl w-full flex flex-col md:flex-row items-stretch">
    
    <div class="bg-[#1a1a1a] flex-1 p-12 flex flex-col justify-between gap-10 border-r border-white/5">
      <div class="flex justify-between items-center">
        <p class="text-white font-bold italic uppercase text-sm">FC BARCELONA</p>
        <p class="text-[#ffcc00] text-5xl font-black italic">100</p>
      </div>
      <div class="flex flex-col gap-4">
        <div class="h-1.5 w-full bg-white/10">
          <div class="h-full w-[45%] bg-gradient-to-r from-[#e21b22] to-[#00529b]"></div>
        </div>
        <p class="text-gray-500 text-[10px] font-bold uppercase tracking-widest">Victorias Totales</p>
      </div>
    </div>

    <div class="relative flex-1 min-h-[300px] flex flex-col items-center justify-center text-center p-12 overflow-hidden">
      <img src="/estado-index.png" class="absolute inset-0 w-full h-full object-cover opacity-20" alt="Background">
      <div class="relative z-10 flex flex-col gap-8">
        <div class="flex flex-col gap-1">
          <p class="text-[#ffcc00] text-6xl font-black italic leading-none">254</p>
          <p class="text-white/60 text-[9px] font-bold uppercase tracking-widest">Pastidos Oficiales</p>
        </div>
        <div class="flex flex-col gap-1">
          <p class="text-white text-3xl font-black italic leading-none">52</p>
          <p class="text-white/60 text-[9px] font-bold uppercase tracking-widest">Empates</p>
        </div>
      </div>
    </div>

    <div class="bg-[#1a1a1a] flex-1 p-12 flex flex-col justify-between gap-10 border-l border-white/5">
      <div class="flex justify-between items-center">
        <p class="text-[#ffcc00] text-5xl font-black italic">102</p>
        <p class="text-white font-bold italic uppercase text-sm">REAL MADRID</p>
      </div>
      <div class="flex flex-col gap-4 items-end">
        <div class="h-1.5 w-full bg-white/10 flex justify-end">
          <div class="h-full w-[48%] bg-white"></div>
        </div>
        <p class="text-gray-500 text-[10px] font-bold uppercase tracking-widest">Victorias Totales</p>
      </div>
    </div>

  </div>
</div>
    </section>

    <section class="bg-black text-white py-10 px-5 font-sans">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-10">
        
        <div class="flex flex-col gap-4 md:w-1/3">
            <h2 class="font-bold text-sm tracking-widest border-l-2 border-yellow-600 pl-3 mb-4">
                MÁXIMOS GOLEADORES DE TODOS LOS TIEMPOS
            </h2>
            
            <div class="bg-[#1a1a1a] flex items-center p-4 gap-4 border border-gray-800">
                <img src="/messi-fc.png" alt="Messi" class="w-16 h-20 object-cover grayscale">
                <div>
                    <p class="uppercase text-yellow-500 text-[10px] font-bold tracking-tighter">Barcelona</p>
                    <p class="font-bold text-lg leading-tight">LIONEL MESSI</p>
                    <p class="text-red-600 font-bold text-xl">26</p>
                </div>
            </div>

            <div class="bg-[#1a1a1a] flex items-center p-4 gap-4 border border-gray-800">
                <img src="/Cristiano-Ronaldo-RM.png" alt="Cristiano" class="w-16 h-20 object-cover grayscale">
                <div>
                    <p class="uppercase text-gray-400 text-[10px] font-bold tracking-tighter">Real Madrid</p>
                    <p class="font-bold text-lg leading-tight">CRISTIANO RONALDO</p>
                    <p class="text-red-600 font-bold text-xl">18</p>
                </div>
            </div>

            <div class="bg-[#1a1a1a] flex items-center p-4 gap-4 border border-gray-800">
                <img src="/Alfredo-Di-Stefano-RM.png" alt="Di Stefano" class="w-16 h-20 object-cover grayscale">
                <div>
                    <p class="uppercase text-gray-400 text-[10px] font-bold tracking-tighter">Real Madrid</p>
                    <p class="font-bold text-lg leading-tight">ALFREDO DI STEFANO</p>
                    <p class="text-red-600 font-bold text-xl">18</p>
                </div>
            </div>
        </div>

        <div class="flex-1">
            <h2 class="font-bold text-sm tracking-widest text-right mb-8">
                RECORDS DE TODOS LOS TIEMPOS
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-[#1a1a1a] p-8 border border-gray-800 flex flex-col justify-between min-h-[160px]">
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">La Mayor Victoria</p>
                    <div>
                        <p class="text-4xl font-black italic text-yellow-500">11 - 1</p>
                        <p class="text-[10px] font-bold text-gray-300">REAL MADRID (1943)</p>
                    </div>
                </div>

                <div class="bg-[#1a1a1a] p-8 border border-gray-800 flex flex-col justify-between min-h-[160px]">
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">La mayoría de las apariciones</p>
                    <div>
                        <p class="text-3xl font-black italic uppercase">45 Partidos</p>
                        <p class="text-[10px] font-bold text-gray-300 uppercase">Messi y Sergio Ramos</p>
                    </div>
                </div>

                <div class="bg-[#1a1a1a] p-8 border border-gray-800 flex flex-col justify-between min-h-[160px]">
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Gol más rápido</p>
                    <div>
                        <p class="text-3xl font-black italic uppercase">21 Segundos</p>
                        <p class="text-[10px] font-bold text-gray-300 uppercase">Karim Benzema (2011)</p>
                    </div>
                </div>

                <div class="bg-[#1a1a1a] p-8 border border-gray-800 flex flex-col justify-between min-h-[160px]">
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">La mayoría de las asistencias</p>
                    <div>
                        <p class="text-4xl font-black italic text-yellow-500">14</p>
                        <p class="text-[10px] font-bold text-gray-300 uppercase">Lionel Messi</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
    
    <section>
        <div class="bg-[#0f0f0f] min-h-screen p-12 flex flex-col items-center justify-center font-sans">
  
  <div class="max-w-4xl w-full flex flex-col gap-6">
    
    <div class="flex items-center gap-3 mb-2">
      <div class="text-[#ffcc00]">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <p class="text-white text-2xl font-black italic uppercase tracking-tight">
        RECENT RESULTS
      </p>
    </div>

    <div class="flex flex-col gap-4">
      
      <div class="bg-[#1c1c1c] flex items-center justify-between p-8 rounded-sm group hover:bg-[#252525] transition-colors cursor-pointer">
        <p class="text-gray-500 text-xs font-bold uppercase w-20">APR 24</p>
        
        <div class="flex-1 flex items-center justify-center gap-12">
          <p class="text-white font-black italic uppercase text-lg text-right w-40">REAL MADRID</p>
          <div class="bg-[#2a2a2a] px-6 py-3 rounded-sm border border-white/5">
            <p class="text-white text-3xl font-black italic">3 - 2</p>
          </div>
          <p class="text-gray-400 font-bold italic uppercase text-lg w-40">FC BARCELONA</p>
        </div>

        <div class="text-[#ffcc00] w-20 flex justify-end">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>

      <div class="bg-[#1c1c1c] flex items-center justify-between p-8 rounded-sm group hover:bg-[#252525] transition-colors cursor-pointer">
        <p class="text-gray-500 text-xs font-bold uppercase w-20">JAN 24</p>
        
        <div class="flex-1 flex items-center justify-center gap-12">
          <p class="text-white font-black italic uppercase text-lg text-right w-40">REAL MADRID</p>
          <div class="bg-[#2a2a2a] px-6 py-3 rounded-sm border border-white/5">
            <p class="text-white text-3xl font-black italic">4 - 1</p>
          </div>
          <p class="text-gray-400 font-bold italic uppercase text-lg w-40">FC BARCELONA</p>
        </div>

        <div class="text-[#ffcc00] w-20 flex justify-end">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>

      <div class="bg-[#1c1c1c] flex items-center justify-between p-8 rounded-sm border-l-4 border-[#e21b22] group hover:bg-[#252525] transition-colors cursor-pointer">
        <p class="text-gray-500 text-xs font-bold uppercase w-20">OCT 23</p>
        
        <div class="flex-1 flex items-center justify-center gap-12">
          <p class="text-gray-400 font-bold italic uppercase text-lg text-right w-40">FC BARCELONA</p>
          <div class="bg-[#2a2a2a] px-6 py-3 rounded-sm border border-white/5">
            <p class="text-white text-3xl font-black italic">1 - 2</p>
          </div>
          <p class="text-white font-black italic uppercase text-lg w-40">REAL MADRID</p>
        </div>

        <div class="text-[#ffcc00] w-20 flex justify-end">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>

    </div>
  </div>
</div>
    </section>
</Layout>